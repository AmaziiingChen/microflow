# ============================================================
# MicroFlow .gitignore
# ============================================================

# === macOS ===
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# === Windows ===
Thumbs.db
ehthumbs.db
Desktop.ini

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

# === PyInstaller ===
*.manifest
# 🌟 核心修改 1：取消对 .spec 的屏蔽，确保 MicroFlow.spec 能推送到 GitHub
# *.spec  

# === 虚拟环境 ===
.venv/
venv/
ENV/
env/

# === 环境变量 ===
.env
.env.local
.env.*.local

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~

# === Claude Code ===
.claude/

# === 数据与日志 (白名单控制) ===
# 🌟 核心修改 2：只忽略动态生成的文件，放行静态资源(如图标和默认配置)
data/*
!data/icons/
!data/config.json
*.db
*.log
*.sqlite
*.sqlite3
data/analysis_plots/
data/analysis_plots_1/

# === 前端 ===
frontend/fonts/custom_font.ttf
frontend/fonts/custom_font.otf
frontend/fonts/custom_font.woff
frontend/fonts/custom_font.woff2

# === 测试与覆盖率 ===
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# === Demo 测试文件 ===
demo*.html